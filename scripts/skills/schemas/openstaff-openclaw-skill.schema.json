{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstaff.local/schemas/skills/openstaff-openclaw-skill.schema.json",
  "title": "OpenStaffOpenClawSkillArtifactV1",
  "type": "object",
  "required": [
    "schemaVersion",
    "skillName",
    "knowledgeItemId",
    "taskId",
    "sessionId",
    "source",
    "provenance",
    "mappedOutput",
    "llmOutputAccepted",
    "createdAt",
    "generatorVersion"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "openstaff.openclaw-skill.v1"
    },
    "skillName": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
    },
    "knowledgeItemId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "knowledgeItemPath",
        "llmOutputPath"
      ],
      "properties": {
        "knowledgeItemPath": {
          "type": "string",
          "minLength": 1
        },
        "llmOutputPath": {
          "type": "string",
          "minLength": 1
        },
        "preferenceProfilePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "taskFamily": {
          "type": [
            "string",
            "null"
          ]
        },
        "skillFamily": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "knowledge",
        "sourceTrace",
        "skillBuild",
        "stepMappings"
      ],
      "properties": {
        "knowledge": {
          "type": "object",
          "required": [
            "knowledgeItemId",
            "knowledgeSchemaVersion",
            "taskId",
            "sessionId",
            "knowledgeCreatedAt",
            "knowledgeGeneratorVersion"
          ],
          "properties": {
            "knowledgeItemId": {
              "type": "string",
              "minLength": 1
            },
            "knowledgeSchemaVersion": {
              "type": "string",
              "minLength": 1
            },
            "taskId": {
              "type": "string",
              "minLength": 1
            },
            "sessionId": {
              "type": "string",
              "minLength": 1
            },
            "knowledgeCreatedAt": {
              "type": "string",
              "minLength": 1
            },
            "knowledgeGeneratorVersion": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "sourceTrace": {
          "type": "object",
          "required": [
            "taskChunkSchemaVersion",
            "startTimestamp",
            "endTimestamp",
            "eventCount",
            "boundaryReason"
          ],
          "properties": {
            "taskChunkSchemaVersion": {
              "type": "string",
              "minLength": 1
            },
            "startTimestamp": {
              "type": "string",
              "minLength": 1
            },
            "endTimestamp": {
              "type": "string",
              "minLength": 1
            },
            "eventCount": {
              "type": "integer",
              "minimum": 0
            },
            "boundaryReason": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "skillBuild": {
          "type": "object",
          "required": [
            "skillName",
            "skillSchemaVersion",
            "skillGeneratorVersion",
            "generatedAt",
            "repairVersion",
            "llmOutputAccepted"
          ],
          "properties": {
            "skillName": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
            },
            "skillSchemaVersion": {
              "type": "string",
              "const": "openstaff.openclaw-skill.v1"
            },
            "skillGeneratorVersion": {
              "type": "string",
              "minLength": 1
            },
            "generatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "repairVersion": {
              "type": "integer",
              "minimum": 0
            },
            "llmOutputAccepted": {
              "type": "boolean"
            },
            "preferenceProfileVersion": {
              "type": [
                "string",
                "null"
              ]
            },
            "appliedPreferenceRuleIds": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "preferenceSummary": {
              "type": [
                "string",
                "null"
              ]
            },
            "taskFamily": {
              "type": [
                "string",
                "null"
              ]
            },
            "skillFamily": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "stepMappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "skillStepId",
              "knowledgeStepId",
              "instruction",
              "sourceEventIds",
              "preferredLocatorType",
              "coordinate",
              "semanticTargets"
            ],
            "properties": {
              "skillStepId": {
                "type": "string",
                "pattern": "^step-[0-9]{3}$"
              },
              "knowledgeStepId": {
                "type": "string",
                "minLength": 1
              },
              "instruction": {
                "type": "string",
                "minLength": 1
              },
              "sourceEventIds": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "preferredLocatorType": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "coordinate": {
                "type": [
                  "object",
                  "null"
                ],
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  },
                  "coordinateSpace": {
                    "type": "string"
                  }
                },
                "required": [
                  "x",
                  "y",
                  "coordinateSpace"
                ],
                "additionalProperties": false
              },
              "semanticTargets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "locatorType",
                    "confidence",
                    "source"
                  ],
                  "properties": {
                    "locatorType": {
                      "type": "string",
                      "minLength": 1
                    },
                    "appBundleId": {
                      "type": "string"
                    },
                    "windowTitlePattern": {
                      "type": "string"
                    },
                    "elementRole": {
                      "type": "string"
                    },
                    "elementTitle": {
                      "type": "string"
                    },
                    "elementIdentifier": {
                      "type": "string"
                    },
                    "boundingRect": {
                      "type": "object",
                      "properties": {
                        "x": {
                          "type": "number"
                        },
                        "y": {
                          "type": "number"
                        },
                        "width": {
                          "type": "number"
                        },
                        "height": {
                          "type": "number"
                        },
                        "coordinateSpace": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "x",
                        "y",
                        "width",
                        "height",
                        "coordinateSpace"
                      ],
                      "additionalProperties": false
                    },
                    "confidence": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "source": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": true
                }
              },
              "actionKind": {
                "type": "string",
                "enum": [
                  "nativeAction",
                  "guiAction"
                ]
              },
              "preferredNativeStrategy": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "nativeStrategyOrder": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "locatorStrategyOrder": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "appliedRuleIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "requiresTeacherConfirmation": {
                "type": "boolean"
              },
              "notes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "mappedOutput": {
      "type": "object",
      "required": [
        "objective",
        "context",
        "executionPlan",
        "safetyNotes",
        "confidence"
      ],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "object",
          "required": [
            "appName",
            "appBundleId",
            "windowTitle"
          ],
          "properties": {
            "appName": {
              "type": "string",
              "minLength": 1
            },
            "appBundleId": {
              "type": "string",
              "minLength": 1
            },
            "windowTitle": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "executionPlan": {
          "type": "object",
          "required": [
            "requiresTeacherConfirmation",
            "steps",
            "completionCriteria",
            "failurePolicy"
          ],
          "properties": {
            "requiresTeacherConfirmation": {
              "type": "boolean"
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "stepId",
                  "actionType",
                  "instruction",
                  "target",
                  "sourceEventIds"
                ],
                "properties": {
                  "stepId": {
                    "type": "string",
                    "pattern": "^step-[0-9]{3}$"
                  },
                  "actionType": {
                    "type": "string",
                    "enum": [
                      "openApp",
                      "click",
                      "input",
                      "shortcut",
                      "wait",
                      "unknown"
                    ]
                  },
                  "instruction": {
                    "type": "string",
                    "minLength": 1
                  },
                  "target": {
                    "type": "string",
                    "minLength": 1
                  },
                  "sourceEventIds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "completionCriteria": {
              "type": "object",
              "required": [
                "expectedStepCount",
                "requiredFrontmostAppBundleId"
              ],
              "properties": {
                "expectedStepCount": {
                  "type": "integer",
                  "minimum": 1
                },
                "requiredFrontmostAppBundleId": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            },
            "failurePolicy": {
              "type": "object",
              "required": [
                "onContextMismatch",
                "onStepError",
                "onUnknownAction"
              ],
              "properties": {
                "onContextMismatch": {
                  "type": "string",
                  "const": "stopAndAskTeacher"
                },
                "onStepError": {
                  "type": "string",
                  "const": "stopAndAskTeacher"
                },
                "onUnknownAction": {
                  "type": "string",
                  "const": "stopAndAskTeacher"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "safetyNotes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "llmOutputAccepted": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatorVersion": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
