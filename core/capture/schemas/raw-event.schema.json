{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstaff.local/schemas/capture/raw-event.schema.json",
  "title": "RawEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "sessionId",
    "timestamp",
    "source",
    "action",
    "pointer",
    "contextSnapshot"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "capture.raw.v0"
    },
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "sessionId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "mouse",
        "keyboard"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "leftClick",
        "rightClick",
        "doubleClick",
        "leftMouseDragged",
        "leftMouseUp",
        "keyDown"
      ]
    },
    "pointer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "coordinateSpace"
      ],
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "coordinateSpace": {
          "type": "string",
          "enum": [
            "screen"
          ]
        }
      }
    },
    "contextSnapshot": {
      "$ref": "./context-snapshot.schema.json"
    },
    "modifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "command",
          "shift",
          "option",
          "control"
        ]
      },
      "uniqueItems": true
    },
    "keyboard": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "keyCode",
            "isRepeat",
            "isSensitiveInput"
          ],
          "properties": {
            "keyCode": {
              "type": "integer"
            },
            "characters": {
              "type": [
                "string",
                "null"
              ]
            },
            "charactersIgnoringModifiers": {
              "type": [
                "string",
                "null"
              ]
            },
            "isRepeat": {
              "type": "boolean"
            },
            "isSensitiveInput": {
              "type": "boolean"
            },
            "redactionReason": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
